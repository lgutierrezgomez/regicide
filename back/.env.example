# Copy to .env for local overrides (never commit .env).

# Server port (default 3000)
PORT=3000

# Comma-separated allowed origins for CORS (production).
# Leave unset in dev to allow all origins.
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Remove idle rooms after all players disconnect (ms). Default 300000 (5 min). 0 = off.
# ROOM_IDLE_CLEANUP_MS=300000

# No API keys are required for the current MVP.
